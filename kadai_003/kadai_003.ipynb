      ],
      "source": [
        "import numpy as np\n",
        "\n",
        "A = np.array([\n",
        "    [0, 1],\n",
        "    [2, 3],\n",
        "    [5, 6],\n",
        "])\n",
        "\n",
        "B = np.array([\n",
        "    [0,1,2,3,],\n",
        "    [4,5,6,7,]\n",
        "])\n",
        "\n",
        "\n",
        "C = np.dot(A, B)\n",
        "\n",
        "\n",
        "print(\"行列の積の結果:\")\n",
        "print(C)\n",
        "\n",
        "\n",
        "max_value = np.max(C)\n",
        "\n",
        "print(\"最大値:\", max_value)"
      ]
    }
  ]
